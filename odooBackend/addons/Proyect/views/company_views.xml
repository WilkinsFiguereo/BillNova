<odoo>

    <record id="view_company_list_custom" model="ir.ui.view">
        <field name="name">res.company.list.custom</field>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <list string="Empresas">
                <field name="name"/>
                <field name="ruc"/>
                <field name="sector"/>
                <field name="company_size"/>
                <field name="moderation_status"/>
                <field name="moderation_updated_at"/>
                <field name="contact_email"/>
                <field name="contact_phone"/>
                <field name="country_name"/>
            </list>
        </field>
    </record>

    <record id="view_company_form_custom" model="ir.ui.view">
        <field name="name">res.company.form.custom</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Informacion de Empresa">
                    <field name="name"/>
                    <field name="ruc"/>
                    <field name="sector"/>
                    <field name="founding_year"/>
                    <field name="company_size"/>
                    <field name="website"/>
                    <field name="moderation_status"/>
                    <field name="moderation_updated_at" readonly="1"/>
                    <field name="moderation_reason"/>
                </group>

                <group string="Direccion Fiscal">
                    <field name="country_name"/>
                    <field name="address_state"/>
                    <field name="address_city"/>
                    <field name="full_address"/>
                    <field name="postal_code"/>
                </group>

                <group string="Responsable Administrativo">
                    <field name="admin_full_name"/>
                    <field name="admin_email"/>
                    <field name="admin_phone"/>
                    <field name="admin_position"/>
                </group>

                <group string="Contacto Empresa">
                    <field name="contact_name"/>
                    <field name="contact_email"/>
                    <field name="contact_phone"/>
                </group>

                <group string="Seguridad">
                    <field name="access_password" password="True"/>
                    <field name="confirm_password" password="True"/>
                    <field name="accept_terms"/>
                    <field name="accept_marketing"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_company_custom" model="ir.actions.act_window">
        <field name="name">Empresas</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_company_custom"
              name="Empresas"
              parent="menu_proyect_root"
              action="action_company_custom"
              sequence="1"/>

</odoo>
