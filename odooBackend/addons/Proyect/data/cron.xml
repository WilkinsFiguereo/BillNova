<odoo>
    <data noupdate="1">

        <record id="cron_generate_service_invoices" model="ir.cron">
            <field name="name">Generar facturas de servicios</field>

            <!-- MUY IMPORTANTE: referencia al modelo -->
            <field name="model_id" ref="model_billnova_subscription"/>

            <field name="state">code</field>
            <field name="code">model.cron_generate_service_invoices()</field>

            <!-- Cada cuánto se ejecuta -->
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="active">True</field>
        </record>

    </data>
</odoo>